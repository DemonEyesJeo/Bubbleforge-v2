{
  "name": "bubbleforge-v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --host 127.0.0.1 --port 5173",
    "dev:today": "concurrently -k -n frontend,backend -c cyan,green \"npm run dev:local\" \"npm run backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "python backend/server.py",
    "health": "curl -s http://localhost:5000/api/health",
    "android": "vite build && npx cap sync android && npx cap open android"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0"
  }
}
